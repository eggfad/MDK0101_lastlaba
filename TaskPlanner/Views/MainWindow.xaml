<Window x:Class="TaskPlanner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TaskPlanner.ViewModels"
        xmlns:conv="clr-namespace:TaskPlanner.Converters"
        Title="📅 Планировщик задач" Height="620" Width="820"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <conv:DeadlineColorConverter x:Key="DeadlineColor"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Текущее время -->
        <TextBlock Grid.Row="0" 
                   Text="{Binding CurrentTime}" 
                   FontSize="18" FontWeight="SemiBold" 
                   HorizontalAlignment="Center" 
                   Margin="0,0,0,16"/>

        <!-- Форма добавления задачи -->
        <Border Grid.Row="1" Background="#F0F0F0" CornerRadius="8" 
                Padding="16" Margin="0,0,0,16" BorderBrush="#DDD" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" 
                         Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                         Padding="8,6" FontSize="14" Margin="0,0,8,0"
                         VerticalContentAlignment="Center"/>

                <DatePicker Grid.Column="1" 
                            SelectedDate="{Binding NewTaskDeadline}"
                            Margin="0,0,8,0" FontSize="14"/>

                <Button Grid.Column="2" 
                        Content="+ Добавить"
                        Command="{Binding AddTaskCommand}"
                        Background="#4CAF50" Foreground="White"
                        FontWeight="Bold" FontSize="14"
                        Padding="16,6" BorderThickness="0"
                        Cursor="Hand"/>
            </Grid>
        </Border>

        <!-- Список задач -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Tasks}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#FAFAFA" CornerRadius="6" 
                                Margin="0,0,0,8" Padding="14,10"
                                BorderBrush="#E0E0E0" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Название -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" 
                                               FontSize="15" FontWeight="Medium"/>
                                    <TextBlock Text="{Binding DeadlineFormatted}" 
                                               FontSize="11" Foreground="Gray" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Оставшееся время -->
                                <TextBlock Grid.Column="1" 
                                           Text="{Binding TimeLeftFormatted}"
                                           Foreground="{Binding IsOverdue, Converter={StaticResource DeadlineColor}}"
                                           FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Right"
                                           Margin="0,0,12,0"/>

                                <!-- Кнопка "Готово" -->
                                <Button Grid.Column="2" 
                                        Content="✓ Готово"
                                        Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.CompleteTaskCommand}"
                                        CommandParameter="{Binding}"
                                        Background="#81C784" Foreground="White"
                                        FontSize="12" FontWeight="Bold"
                                        Padding="10,4" BorderThickness="0"
                                        Margin="0,0,6,0" Cursor="Hand"
                                        Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisibility}}"/>

                                <!-- Кнопка "Удалить" -->
                                <Button Grid.Column="3" 
                                        Content="✕"
                                        Command="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=DataContext.RemoveTaskCommand}"
                                        CommandParameter="{Binding}"
                                        Background="#E57373" Foreground="White"
                                        FontSize="12" FontWeight="Bold"
                                        Padding="8,4" BorderThickness="0"
                                        Cursor="Hand"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Кнопка печати -->
        <Button Grid.Row="3" 
                Content="🖨️ Распечатать список задач"
                Click="PrintButton_Click"
                Background="#FF9800" Foreground="White"
                FontSize="14" FontWeight="Bold"
                Padding="20,10" BorderThickness="0"
                HorizontalAlignment="Right"
                Margin="0,12,0,0" Cursor="Hand"/>
    </Grid>
</Window>